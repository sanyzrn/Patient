# ────────────────────────────────────────────────
# Frontend (Vite — embedded in JS bundle at build time)
# ────────────────────────────────────────────────

# Admin Panel Password
VITE_ADMIN_PASSWORD=your-secure-password-here

# Token sent in X-Form-Token header to PHP endpoints
VITE_CHAT_FORM_TOKEN=your-form-token-here

# ────────────────────────────────────────────────
# Server-side (PHP — set in hosting panel or .htaccess)
# These must NEVER be committed to git
# ────────────────────────────────────────────────

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://nafaspharmed.com,https://www.nafaspharmed.com

# Must match VITE_ADMIN_PASSWORD — used by api.php to authenticate save requests
ADMIN_API_TOKEN=your-secure-password-here

# Must match VITE_CHAT_FORM_TOKEN — used by chat.php and submit_form.php
CHAT_FORM_TOKEN=your-form-token-here
FORM_SUBMIT_TOKEN=your-form-token-here

# Bale bot credentials (get new token after revoking the old one)
BALE_TOKEN=your-bale-bot-token
BALE_CHAT_ID=your-bale-chat-id

# Gemini API key — enables real AI in chat.php
GEMINI_API_KEY=your-gemini-api-key
